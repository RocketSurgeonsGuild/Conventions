<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <TargetFramework>netstandard2.0</TargetFramework>
        <IsRoslynComponent>true</IsRoslynComponent>
        <DefineConstants>$(DefineConstants);ROSLYN_CURRENT</DefineConstants>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
        <NoWarn>$(NoWarn);MSB3277</NoWarn>
        <_AnalyzersLocation>../Conventions.Analyzers.supports/bin/</_AnalyzersLocation>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
        <PackageReference Include="Polyfill" PrivateAssets="all" />
        <PackageReference Include="System.Collections.Immutable" VersionOverride="10.0.9" />
        <PackageReference Include="System.Text.Json" PrivateAssets="all" GeneratePathProperty="true" />
        <ProjectReference
            Include="../Conventions.Analyzers.supports/Rocket.Surgery.Conventions.Analyzers.roslyn4.14.csproj"
            PrivateAssets="all"
            ReferenceOutputAssembly="false"
        />
        <ProjectReference
            Include="../Conventions.Analyzers.supports/Rocket.Surgery.Conventions.Analyzers.roslyn5.0.csproj"
            PrivateAssets="all"
            ReferenceOutputAssembly="false"
        />
    </ItemGroup>
    <ItemGroup>
        <None Include="bin\$(Configuration)\netstandard2.0\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/roslyn5.3/cs" Visible="false" />
        <None
            Include="$(PkgSystem_Text_Json)\lib\netstandard2.0\System.Text.Json.dll"
            Pack="true"
            PackagePath="analyzers/dotnet/roslyn5.3/cs"
            Visible="false"
        />
        <None
            Include="$(_AnalyzersLocation)roslyn5.0/$(Configuration)/netstandard2.0/Conventions.Analyzers.dll"
            Pack="true"
            PackagePath="analyzers/dotnet/roslyn5.0/cs"
            Visible="false"
        />
        <None
            Include="$(_AnalyzersLocation)roslyn5.0/$(Configuration)/netstandard2.0/System.Text.Json.dll"
            Pack="true"
            PackagePath="analyzers/dotnet/roslyn5.0/cs"
            Visible="false"
        />
        <None
            Include="$(_AnalyzersLocation)roslyn4.14/$(Configuration)/netstandard2.0/Conventions.Analyzers.dll"
            Pack="true"
            PackagePath="analyzers/dotnet/roslyn4.14/cs"
            Visible="false"
        />
        <None
            Include="$(_AnalyzersLocation)roslyn4.14/$(Configuration)/netstandard2.0/System.Text.Json.dll"
            Pack="true"
            PackagePath="analyzers/dotnet/roslyn4.14/cs"
            Visible="false"
        />
    </ItemGroup>
</Project>
