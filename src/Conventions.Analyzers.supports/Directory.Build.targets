<Project>
    <ItemGroup>
        <PackageReference Include="Polyfill" PrivateAssets="all" />
        <Compile
            Include="$(MSBuildThisFileDirectory)..\Rocket.Surgery.Conventions.Analyzers\**\*.cs"
            Exclude="$(MSBuildThisFileDirectory)..\Rocket.Surgery.Conventions.Analyzers\obj\**\*.cs"
        />
        <None Include="$(PkgSystem_Text_Json)\lib\netstandard2.0\System.Text.Json.dll" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>
    <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.targets', '$(MSBuildThisFileDirectory)../'))" />
</Project>
