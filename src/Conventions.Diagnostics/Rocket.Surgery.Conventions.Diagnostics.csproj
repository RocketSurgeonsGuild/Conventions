<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <PackageDescription>
            Adds diagnostics command line utilities for diagnosing what conventions are
      available to be run
        </PackageDescription>
        <PackageTags>$(PackageTags);reflection;diagnostics</PackageTags>
        <NoWarn>$(NoWarn);CA1812</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="..\Conventions\Rocket.Surgery.Conventions.csproj" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="System.Diagnostics.DiagnosticSource" />
    </ItemGroup>
</Project>
